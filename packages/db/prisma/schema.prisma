generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator seed {
  provider = "prisma" // placeholder — seed runs via package.json script
}

// ─── Auth ───────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  phone         String?
  name          String?
  avatarUrl     String?
  image         String?
  role          UserRole  @default(ATTENDEE)
  emailVerified DateTime?
  phoneVerified Boolean   @default(false)
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  organization     Organization?
  orders           Order[]
  reviews          Review[]
  eventFavorites   EventFavorite[]
  organizerFollows OrganizerFollow[]
  accounts         Account[]
  sessions         Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refreshToken      String? @db.Text
  accessToken       String? @db.Text
  expiresAt         Int?
  tokenType         String?
  scope             String?
  idToken           String? @db.Text
  sessionState      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Verification Tokens (magic link, OTP) ──────────────

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  purpose    String   @default("magic_link")

  @@unique([identifier, token])
}

// ─── Guest / Anonymous Access ───────────────────────────

model GuestToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  purpose   String
  expiresAt DateTime
  usedAt    DateTime?
  orderId   String?
  eventId   String?
  createdAt DateTime @default(now())
}

// ─── Organization ───────────────────────────────────────

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?  @db.Text
  logoUrl     String?
  coverUrl    String?
  website     String?
  phone       String?
  email       String?
  socialLinks Json?

  bankAccountName   String?
  bankAccountNumber String?
  bankCode          String?
  paystackRecipient String?

  ownerId String @unique
  owner   User   @relation(fields: [ownerId], references: [id])

  events    Event[]
  followers OrganizerFollow[]
  payouts   Payout[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Events ─────────────────────────────────────────────

model Event {
  id          String       @id @default(cuid())
  title       String
  slug        String       @unique
  description String       @db.Text
  shortDesc   String?

  coverImage  String?
  gallery     Json?
  videoUrl    String?

  category    EventCategory @default(OTHER)
  eventType   EventType    @default(PHYSICAL)
  tags        String[]     @default([])

  startDate DateTime
  endDate   DateTime
  doorTime  DateTime?
  timezone  String   @default("Africa/Lagos")

  venueName    String?
  venueAddress String?
  city         String?
  state        String?
  country      String   @default("Nigeria")
  lat          Float?
  lng          Float?

  meetingLink     String?
  meetingPassword String?

  status        EventStatus @default(DRAFT)
  capacity      Int?
  isFree        Boolean     @default(false)
  saleStartDate DateTime?
  saleEndDate   DateTime?
  refundPolicy  String?
  minAge        Int?
  viewCount     Int         @default(0)
  ticketSold    Int         @default(0)
  revenueKobo   Int         @default(0)

  contactEmail  String?
  organizerToken String?

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  ticketTypes TicketType[]
  orders      Order[]
  reviews     Review[]
  favorites   EventFavorite[]
  discountCodes DiscountCode[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizerToken])
}

// ─── Ticket Types ───────────────────────────────────────

model TicketType {
  id          String   @id @default(cuid())
  eventId     String
  name        String
  description String?
  priceKobo   Int
  quantity    Int
  maxPerOrder Int      @default(10)
  saleStart   DateTime?
  saleEnd     DateTime?
  isHidden    Boolean  @default(false)
  sortOrder   Int      @default(0)

  event   Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tickets Ticket[]

  @@unique([eventId, name])
}

// ─── Tickets ────────────────────────────────────────────

model Ticket {
  id            String       @id @default(cuid())
  orderId       String
  ticketTypeId  String
  attendeeName  String
  attendeeEmail String
  attendeePhone String?
  qrCode        String       @unique
  status        TicketStatus @default(ACTIVE)
  checkedInAt   DateTime?
  checkedInBy   String?

  order      Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ticketType TicketType @relation(fields: [ticketTypeId], references: [id])

  createdAt DateTime @default(now())
}

// ─── Orders ─────────────────────────────────────────────

model Order {
  id            String        @id @default(cuid())
  orderNumber   String        @unique
  userId        String?
  userEmail     String
  userName      String?
  userPhone     String?
  eventId       String
  subtotalKobo  Int
  serviceFeeKobo Int
  totalKobo     Int
  currency      String        @default("NGN")
  paymentProvider String?
  paymentRef    String?
  paymentStatus PaymentStatus @default(PENDING)
  paidAt        DateTime?

  event   Event   @relation(fields: [eventId], references: [id])
  user    User?   @relation(fields: [userId], references: [id])
  tickets Ticket[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Discount Codes ─────────────────────────────────────

model DiscountCode {
  id            String       @id @default(cuid())
  eventId       String
  code          String
  type          DiscountType
  valueKobo     Int?
  percentage    Int?
  maxUsage      Int?
  currentUsage  Int          @default(0)
  minCartAmount Int?
  expiresAt     DateTime?

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, code])
}

// ─── Reviews ────────────────────────────────────────────

model Review {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  rating    Int
  comment   String?  @db.Text

  event Event @relation(fields: [eventId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@unique([eventId, userId])
}

// ─── Favorites & Follows ────────────────────────────────

model EventFavorite {
  eventId String
  userId  String
  event   Event @relation(fields: [eventId], references: [id])
  user    User  @relation(fields: [userId], references: [id])

  @@id([userId, eventId])
}

model OrganizerFollow {
  organizationId String
  userId         String
  organization   Organization @relation(fields: [organizationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@id([userId, organizationId])
}

// ─── Payouts ────────────────────────────────────────────

model Payout {
  id             String    @id @default(cuid())
  organizationId String
  amountKobo     Int
  feeKobo        Int
  netAmountKobo  Int
  bankName       String
  bankAccount    String
  accountName    String
  reference      String    @unique
  status         PayoutStatus @default(PENDING)
  paidAt         DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  createdAt DateTime @default(now())
}

// ─── Enums ──────────────────────────────────────────────

enum UserRole {
  ATTENDEE
  ORGANIZER
  ADMIN
}

enum EventCategory {
  MUSIC
  TECH
  SPORTS
  ARTS
  FOOD
  BUSINESS
  OTHER
}

enum EventType {
  PHYSICAL
  VIRTUAL
  HYBRID
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

enum TicketStatus {
  ACTIVE
  USED
  REFUNDED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
}
