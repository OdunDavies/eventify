{
  "name": "eventtix",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "pnpm --filter @eventtix/db generate",
    "db:migrate": "pnpm --filter @eventtix/db migrate",
    "db:push": "pnpm --filter @eventtix/db push",
    "db:studio": "pnpm --filter @eventtix/db studio"
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "packageManager": "pnpm@11.2.2",
  "engines": {
    "node": ">=18"
  }
}
